OPENAI_API_KEY=your_api_key_here
DEKONSTRUISTO_MODEL=gpt-4.1-mini
# Optional: override generation temperature
# Defaults to 1 for gpt-5* models and 0.2 otherwise
# DEKONSTRUISTO_TEMPERATURE=1
# Optional: enable model-assisted section normalization by default
# DEKONSTRUISTO_MODEL_SECTIONS=true
# Optional: use a cheaper/faster model for section normalization
# DEKONSTRUISTO_SECTION_MODEL=gpt-4.1-mini
# Optional: override section-normalization temperature
# Defaults to 1 for gpt-5* models and 0.2 otherwise
# DEKONSTRUISTO_SECTION_TEMPERATURE=1
# Optional: point at another OpenAI-compatible endpoint
# OPENAI_BASE_URL=https://api.openai.com/v1
# DEKONSTRUISTO_MAX_CONTEXT_CHARS=60000
